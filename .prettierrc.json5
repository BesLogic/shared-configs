// The source skeleton for this configuration can be found at
// https://github.com/BesLogic/shared-configs/blob/main/.prettierrc.json5
// Modifications to this file that are not project-specific should also be done upstream.

// Note that we prefer recommending dprint over Prettier, but if your project *must* use Prettier,
// here's the configs that most match our recommendations.

{
  "semi": false,
  "singleQuote": true,
  "experimentalOperatorPosition": "start",
  "overrides": [
    {
      "files": "*.y?(a)ml",
      "options": {
        "singleQuote": false,
      },
    },
    {
      // Override editorconfig's `max_line_length = off` for markdown, which sets
      // printWidth to Infinity and collapses embedded code blocks onto one line.
      "files": ["*.md"],
      "options": {
        "printWidth": 100,
      },
    },
    {
      // Most json files nowadays will support trailing commas and comments
      "files": ["*.json"],
      "options": {
        "parser": "jsonc",
        "trailingComma": "all",
      },
    },
    {
      // Known json w/o trailing comma or comments support
      "files": ["package.json", "*.code-workspace", "eslint-suppressions.json", ".mcp.json"],
      "options": {
        "parser": "json",
        "trailingComma": "none",
      },
    },
    {
      // Have json5 files look like json as much as possible to avoid needing special syntax highlight in most cases
      "files": ["*.json5"],
      "options": {
        "singleQuote": false,
        "quoteProps": "preserve",
      },
    },
  ],
}
